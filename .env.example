# ── API密钥 ──────────────────────────────────────────────────
# 百炼平台API密钥（用于embedding向量生成 + LLM描述生成）
DASHSCOPE_API_KEY=
# Anthropic API密钥（用于LLM描述生成，仅当LLM_PROVIDER使用anthropic模型时需要）
ANTHROPIC_API_KEY=

# ── LLM配置 ─────────────────────────────────────────────────
# LLM模型provider，格式: provider/model（litellm格式）
# 百炼: openai/qwen-plus-2025-04-28, openai/qwen-turbo, openai/qwen3-235b-a22b 等
# Anthropic: anthropic/claude-sonnet-4-6
# Groq: groq/llama3, OpenAI: openai/gpt-4o 等
# 使用百炼时需同时设置LLM_BASE_URL和LLM_API_KEY_ENV
LLM_PROVIDER=openai/deepseek-v4-flash
# LLM API接口地址（百炼OpenAI兼容模式，使用anthropic时留空）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM密钥引用的env var名称（使用百炼时设为DASHSCOPE_API_KEY，使用anthropic时设为ANTHROPIC_API_KEY）
LLM_API_KEY_ENV=DASHSCOPE_API_KEY

# ── Embedding配置 ────────────────────────────────────────────
# embedding模型provider（去掉dashscope/前缀后作为模型名传入百炼API）
# 可选: dashscope/text-embedding-v4, dashscope/text-embedding-v3
EMBEDDING_PROVIDER=dashscope/text-embedding-v4
# embedding密钥引用的env var名称（不是密钥值本身，是env var的名字）
EMBEDDING_API_KEY_ENV=DASHSCOPE_API_KEY
# embedding API接口地址（百炼OpenAI兼容模式）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# 向量维度（可选: 256, 512, 768, 1024, 1536, 2048）
# 注意：改维度后需重新run索引，已有向量库会失效
EMBEDDING_DIMENSIONS=1024

# ── 向量数据库配置 ──────────────────────────────────────────
# 向量数据库类型（目前仅支持chromadb）
VECTOR_BACKEND=chromadb
# 向量库持久化目录（相对于仓库根目录）
VECTOR_PERSIST_DIR=.indexer/vector_db
# ChromaDB collection名称
VECTOR_COLLECTION_NAME=repo_code
